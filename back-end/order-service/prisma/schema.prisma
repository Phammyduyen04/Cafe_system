generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Order {
  order_id         String    @id @default(uuid()) @db.VarChar(36)
  customer_id      String?   @db.VarChar(36)
  order_code       String    @unique @db.VarChar(50)
  order_time       DateTime  @default(now())
  order_type       String    @db.VarChar(20) // DINE_IN, TAKE_AWAY
  order_channel    String    @default("IN_STORE") @db.VarChar(20) // ONLINE, IN_STORE
  payment_method   String    @default("CASH") @db.VarChar(20) // CASH, MOMO, QR
  status           String    @default("PENDING") @db.VarChar(20)
  subtotal_amount  Decimal   @default(0) @db.Decimal(12, 2)
  discount_amount  Decimal   @default(0) @db.Decimal(12, 2)
  promotion_amount Decimal   @default(0) @db.Decimal(12, 2)
  total_amount     Decimal   @default(0) @db.Decimal(12, 2)
  note             String?   @db.Text
  created_by       String?   @db.VarChar(100)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  order_details    OrderDetail[]
  status_logs      OrderStatusLog[]
  order_discounts  OrderDiscount[]
  order_promotions OrderPromotion[]

  @@map("orders")
}

model OrderDetail {
  order_detail_id String   @id @default(uuid()) @db.VarChar(36)
  order_id        String
  product_id      String   @db.VarChar(50)
  product_name    String   @db.VarChar(200)
  size            String?  @db.VarChar(20) // S, M, L
  sugar_level     String?  @db.VarChar(20) // 0%, 30%, 50%, 70%, 100%
  ice_level       String?  @db.VarChar(20) // 0%, 30%, 50%, 70%, 100%
  unit_price      Decimal  @db.Decimal(12, 2)
  quantity        Int
  item_note       String?  @db.VarChar(255)
  line_total      Decimal  @db.Decimal(12, 2)

  order           Order    @relation(fields: [order_id], references: [order_id], onDelete: Cascade)
  toppings        OrderItemTopping[]

  @@map("order_details")
}

model OrderItemTopping {
  order_item_topping_id String  @id @default(uuid()) @db.VarChar(36)
  order_item_id         String
  topping_id            String? @db.VarChar(50)
  topping_name          String  @db.VarChar(200)
  topping_price         Decimal @db.Decimal(12, 2)
  quantity              Int     @default(1)

  order_detail OrderDetail @relation(fields: [order_item_id], references: [order_detail_id], onDelete: Cascade)

  @@map("order_item_toppings")
}

model OrderStatusLog {
  status_log_id String   @id @default(uuid()) @db.VarChar(36)
  order_id      String
  old_status    String?  @db.VarChar(20)
  new_status    String   @db.VarChar(20)
  changed_by    String?  @db.VarChar(100)
  changed_at    DateTime @default(now())
  note          String?  @db.VarChar(255)

  order Order @relation(fields: [order_id], references: [order_id], onDelete: Cascade)

  @@map("order_status_logs")
}

model OrderDiscount {
  order_discount_id String  @id @default(uuid()) @db.VarChar(36)
  order_id          String
  discount_id       String  @db.VarChar(50)
  discount_name     String  @db.VarChar(200)
  discount_type     String  @db.VarChar(20)
  discount_value    Decimal @db.Decimal(12, 2)
  applied_amount    Decimal @db.Decimal(12, 2)

  order Order @relation(fields: [order_id], references: [order_id], onDelete: Cascade)

  @@map("order_discounts")
}

model OrderPromotion {
  order_promotion_id String  @id @default(uuid()) @db.VarChar(36)
  order_id           String
  promotion_id       String  @db.VarChar(50)
  promotion_name     String  @db.VarChar(200)
  benefit_type       String  @db.VarChar(50)
  benefit_value      Decimal @db.Decimal(12, 2)
  applied_amount     Decimal @db.Decimal(12, 2)

  order Order @relation(fields: [order_id], references: [order_id], onDelete: Cascade)

  @@map("order_promotions")
}

model Cart {
  cart_id     String    @id @default(uuid()) @db.VarChar(36)
  customer_id String   @unique @db.VarChar(36)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  items       CartItem[]

  @@map("carts")
}

model CartItem {
  cart_item_id  String   @id @default(uuid()) @db.VarChar(36)
  cart_id       String
  product_id    String   @db.VarChar(50)
  product_name  String   @db.VarChar(200)
  size          String?  @db.VarChar(20)
  sugar_level   String?  @db.VarChar(20)
  ice_level     String?  @db.VarChar(20)
  unit_price    Decimal  @db.Decimal(12, 2)
  quantity      Int      @default(1)
  item_note     String?  @db.VarChar(255)
  created_at    DateTime @default(now())

  cart          Cart     @relation(fields: [cart_id], references: [cart_id], onDelete: Cascade)
  toppings      CartItemTopping[]

  @@map("cart_items")
}

model CartItemTopping {
  cart_item_topping_id String  @id @default(uuid()) @db.VarChar(36)
  cart_item_id         String
  topping_id           String? @db.VarChar(50)
  topping_name         String  @db.VarChar(200)
  topping_price        Decimal @db.Decimal(12, 2)
  quantity             Int     @default(1)

  cart_item CartItem @relation(fields: [cart_item_id], references: [cart_item_id], onDelete: Cascade)

  @@map("cart_item_toppings")
}
