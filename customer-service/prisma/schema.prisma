generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Customer {
  customer_id     String    @id @default(uuid()) @db.VarChar(36)
  full_name       String    @db.VarChar(150)
  email           String?   @unique @db.VarChar(150)
  phone_number    String?   @unique @db.VarChar(20)
  points          Int       @default(0)
  account_id      String?   @unique @db.VarChar(36)
  customer_status String    @default("ACTIVE") @db.VarChar(20)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  point_logs CustomerPointLog[]

  @@map("customers")
}

model CustomerPointLog {
  point_log_id  String   @id @default(uuid()) @db.VarChar(36)
  customer_id   String
  change_type   String   @db.VarChar(20) // EARN, REDEEM, ADJUST
  points_changed Int
  reason        String?  @db.VarChar(255)
  order_id      String?  @db.VarChar(36)
  created_at    DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)

  @@map("customer_point_logs")
}
