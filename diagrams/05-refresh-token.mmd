sequenceDiagram
    autonumber
    actor User as Nguoi dung
    participant GW as API Gateway
    participant Auth as Auth Service
    participant AuthDB as Auth DB

    User->>GW: POST /api/auth/refresh-token
    Note over Client,GW: refreshToken
    GW->>Auth: Forward request

    activate Auth
    Auth->>AuthDB: refreshToken.findByToken(token)
    AuthDB-->>Auth: token record hoac null

    alt Token khong ton tai
        Auth-->>GW: 401 Unauthorized
        GW-->>User: Refresh token khong hop le
    else Token da bi thu hoi
        Auth-->>GW: 401 Unauthorized
        GW-->>User: Refresh token da bi thu hoi
    else Token da het han
        Auth-->>GW: 401 Unauthorized
        GW-->>User: Refresh token da het han
    else Token hop le
        Auth->>AuthDB: account.findById(accountId)
        AuthDB-->>Auth: account record

        alt Tai khoan khong ton tai hoac bi vo hieu hoa
            Auth-->>GW: 401 Unauthorized
            GW-->>User: Tai khoan khong hop le
        else Tai khoan ACTIVE
            Auth->>AuthDB: getAccountRoles(accountId)
            AuthDB-->>Auth: danh sach roles

            Auth->>Auth: jwt.sign - accessToken moi 15m

            Note over Auth: Rotate refresh token
            Auth->>AuthDB: refreshToken.revoke(tokenId)
            Auth->>Auth: crypto.randomBytes(64) - refreshToken moi
            Auth->>AuthDB: refreshToken.create - het han 7d

            Auth-->>GW: 200 OK
            Note over Auth,GW: accessToken moi, refreshToken moi
            GW-->>User: Tokens da duoc cap lai
        end
    end

    deactivate Auth

