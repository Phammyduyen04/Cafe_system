sequenceDiagram
    autonumber
    actor User as Nguoi dung
    participant GW as API Gateway
    participant Auth as Auth Service
    participant AuthDB as Auth DB

    User->>GW: POST /api/auth/login
    Note over User,GW: username hoac email, password
    GW->>Auth: Forward request

    activate Auth

    Auth->>AuthDB: findByUsername(username)
    AuthDB-->>Auth: account hoac null

    alt Khong tim thay theo username
        Auth->>AuthDB: findByEmail(username)
        AuthDB-->>Auth: account hoac null
    end

    alt Tai khoan khong ton tai
        Auth-->>GW: 401 Unauthorized
        GW-->>User: Ten dang nhap hoac mat khau khong dung
    else Tai khoan bi vo hieu hoa
        Auth-->>GW: 403 Forbidden
        GW-->>User: Tai khoan da bi vo hieu hoa
    else Tai khoan hop le
        Auth->>Auth: bcrypt.compare(password, hash)

        alt Sai mat khau
            Auth-->>GW: 401 Unauthorized
            GW-->>User: Ten dang nhap hoac mat khau khong dung
        else Dung mat khau
            Auth->>AuthDB: getAccountRoles(accountId)
            AuthDB-->>Auth: danh sach roles

            Auth->>Auth: jwt.sign - accessToken het han 15m
            Auth->>Auth: crypto.randomBytes(64) - refreshToken het han 7d

            Auth->>AuthDB: refreshToken.create(token, expiresAt)
            Auth->>AuthDB: updateLastLogin(accountId)

            Auth-->>GW: 200 OK
            Note over Auth,GW: accessToken, refreshToken<br/>accountId, username, roles
            GW-->>User: Dang nhap thanh cong
        end
    end

    deactivate Auth

