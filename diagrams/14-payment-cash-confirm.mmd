sequenceDiagram
    autonumber
    actor NV as Nhan vien
    participant GW as API Gateway
    participant Payment as Payment Service
    participant PaymentDB as Payment DB
    participant MQ as RabbitMQ
    participant Order as Order Service
    participant OrderDB as Order DB

    NV->>GW: POST /api/payments/:paymentId/cash-confirm
    Note over NV,GW: amountReceived, note tuy chon
    GW->>Payment: Forward request - yeu cau auth STAFF

    Payment->>PaymentDB: payment.findById(paymentId)
    PaymentDB-->>Payment: payment record

    alt Payment khong ton tai
        Payment-->>GW: 404 Not Found
        GW-->>NV: Thanh toan khong ton tai
    else Payment da hoan thanh hoac bi huy
        Payment-->>GW: 400 Bad Request
        GW-->>NV: Thanh toan da duoc xu ly truoc do
    else Phuong thuc khong phai CASH
        Payment-->>GW: 400 Bad Request
        GW-->>NV: Phuong thuc thanh toan khong hop le
    else amountReceived nho hon totalAmount
        Payment-->>GW: 400 Bad Request
        GW-->>NV: So tien nhan khong du
    else Hop le
        Payment->>Payment: change = amountReceived - totalAmount
        Payment->>PaymentDB: paymentSession.create
        Note over Payment,PaymentDB: staffId, sessionType=CASH<br/>amountReceived, change, note
        Payment->>PaymentDB: paymentTransaction.create
        Note over Payment,PaymentDB: amount=totalAmount, method=CASH<br/>status=SUCCESS, reference
        Payment->>PaymentDB: payment.update - status=COMPLETED
        PaymentDB-->>Payment: payment da cap nhat

        Payment->>MQ: Publish payment_exchange / payment.completed
        Note over Payment,MQ: orderId, paymentId<br/>totalAmount, method=CASH

        Payment-->>GW: 200 OK
        Note over Payment,GW: paymentId, status=COMPLETED<br/>amountReceived, change
        GW-->>NV: Xac nhan thanh toan tien mat thanh cong
    end

    Note over MQ,OrderDB: Xu ly bat dong bo - Order Service consume

    MQ->>Order: Consume payment_exchange / payment.completed
    Order->>OrderDB: order.findByOrderId(orderId)
    Order->>OrderDB: order.update - status PENDING_PAYMENT -> PAID
    Note over Order,OrderDB: Chi cap nhat neu status la PENDING_PAYMENT<br/>Don IN_STORE da o CONFIRMED - khong thay doi

