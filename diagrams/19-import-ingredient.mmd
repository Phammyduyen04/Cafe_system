sequenceDiagram
    autonumber
    actor MG as Manager
    participant GW as API Gateway
    participant Product as Product Service
    participant ProductDB as Product DB

    MG->>GW: POST /api/products/ingredients/:ingredientId/import
    Note over MG,GW: quantity, unitCost<br/>supplier tuy chon, note tuy chon
    GW->>Product: Forward request - yeu cau auth MANAGER

    Product->>ProductDB: ingredient.findById(ingredientId)
    ProductDB-->>Product: ingredient record

    alt Nguyen lieu khong ton tai
        Product-->>GW: 404 Not Found
        GW-->>MG: Nguyen lieu khong ton tai
    else quantity <= 0 hoac unitCost < 0
        Product-->>GW: 400 Bad Request
        GW-->>MG: Du lieu nhap khong hop le
    else Hop le
        Product->>ProductDB: ingredient.update - currentStock += quantity
        Product->>ProductDB: importLog.create
        Note over Product,ProductDB: ingredientId, quantity, unitCost<br/>supplier, note, importedBy=managerId<br/>totalCost = quantity * unitCost
        ProductDB-->>Product: import da ghi nhan

        Product-->>GW: 201 Created
        Note over Product,GW: importLogId, ingredientId<br/>quantity, currentStock moi, totalCost
        GW-->>MG: Nhap nguyen lieu thanh cong
    end

